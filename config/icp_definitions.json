{
  "segments": {
    "segment_a_buyers": {
      "display_name": "Segment A — Enterprise Grocery / Retail Chains (Buyers)",
      "pipeline": "direct_to_customer",
      "description": "Enterprise-level grocery retailers and wholesale buyers with centralized procurement",
      "outreach_channels": ["email"],
      "priority": 1,

      "qualification_thresholds": {
        "note": "Target companies meeting at least ONE of the following",
        "min_employees": 200,
        "min_revenue_usd": 50000000,
        "min_retail_locations": 20,
        "multi_state_or_multi_country": true,
        "centralized_procurement": true
      },

      "company_types_include": [
        "Regional supermarket chains",
        "National grocery chains",
        "Large discount grocery chains",
        "Cash & carry chains",
        "Large food & beverage wholesalers supplying retail",
        "Large importers supplying retail chains"
      ],

      "company_types_exclude": [
        "Single-location grocery stores",
        "Independent markets",
        "Restaurants",
        "Foodservice-only operators",
        "Companies under 200 employees",
        "Revenue under $20M"
      ],

      "target_departments": [
        "Purchasing",
        "Procurement",
        "Merchandising",
        "Supply Chain",
        "Strategy",
        "Commercial"
      ],

      "title_include_keywords": [
        "procurement",
        "purchasing",
        "merchandising",
        "category",
        "sourcing",
        "commercial",
        "trading",
        "center store",
        "private label",
        "own brand",
        "supply chain"
      ],

      "title_exclude_keywords": [
        "assistant",
        "junior",
        "coordinator",
        "analyst",
        "intern",
        "HR",
        "recruiter",
        "engineer",
        "marketing",
        "finance",
        "accounting"
      ],

      "target_seniorities": ["director", "vp", "c_suite", "head", "partner"],

      "apollo_organization_keyword_tags": [
        "supermarket chain",
        "grocery chain",
        "retail group",
        "regional chain",
        "multi-location",
        "distribution network",
        "cash and carry",
        "corporate office",
        "headquarters",
        "food",
        "grocery",
        "supermarket",
        "food retail"
      ],

      "apollo_employee_ranges": ["201,500", "501,1000", "1001,5000", "5001,10000", "10001,"],

      "apollo_revenue_ranges": ["50000000,100000000", "100000000,500000000", "500000000,1000000000", "1000000000,"]
    },

    "segment_b_suppliers": {
      "display_name": "Segment B — Enterprise Manufacturers / Distributors (Suppliers)",
      "pipeline": "partner",
      "description": "Enterprise-level CPG food manufacturers, snack/confectionery producers, and large distributors",
      "outreach_channels": ["email"],
      "priority": 1,

      "qualification_thresholds": {
        "note": "Target companies meeting at least ONE of the following",
        "min_employees": 100,
        "min_revenue_usd": 25000000,
        "national_or_multi_country_distribution": true,
        "recognized_cpg_brand": true,
        "dedicated_wholesale_channel": true
      },

      "company_types_include": [
        "Packaged food manufacturers",
        "Snack manufacturers",
        "Confectionery manufacturers",
        "Grocery CPG brand owners",
        "Large wholesale food distributors",
        "Large food import/export trading companies",
        "Overstock / surplus food distributors with scale"
      ],

      "company_types_exclude": [
        "Small private label startups",
        "Micro food brands",
        "Local producers",
        "Farms",
        "Beverage-only companies",
        "Restaurants",
        "Equipment suppliers",
        "Companies under $10M revenue"
      ],

      "target_departments": [
        "Sales",
        "Commercial",
        "Wholesale",
        "Channel Sales",
        "Export Sales",
        "Business Development"
      ],

      "title_include_keywords": [
        "sales",
        "commercial",
        "channel sales",
        "wholesale",
        "export",
        "national account",
        "key account",
        "trade sales",
        "revenue"
      ],

      "title_exclude_keywords": [
        "assistant",
        "junior",
        "coordinator",
        "SDR",
        "BDR",
        "HR",
        "recruiter",
        "engineer",
        "marketing",
        "finance",
        "intern"
      ],

      "target_seniorities": ["director", "vp", "c_suite", "head"],

      "apollo_organization_keyword_tags": [
        "manufacturer",
        "food manufacturer",
        "snack manufacturer",
        "confectionery",
        "CPG brand",
        "grocery brand",
        "wholesale distributor",
        "distribution network",
        "export",
        "import",
        "food",
        "food production",
        "consumer packaged goods"
      ],

      "apollo_employee_ranges": ["101,200", "201,500", "501,1000", "1001,5000", "5001,10000", "10001,"],

      "apollo_revenue_ranges": ["25000000,50000000", "50000000,100000000", "100000000,500000000", "500000000,1000000000", "1000000000,"]
    }
  },

  "geography": {
    "included_regions": {
      "united_states": {
        "label": "United States",
        "apollo_locations": ["United States"]
      },
      "united_kingdom": {
        "label": "United Kingdom",
        "apollo_locations": ["United Kingdom"]
      },
      "eu_eea_switzerland": {
        "label": "EU / EEA / Switzerland / Norway / Hungary",
        "apollo_locations": [
          "Germany", "France", "Netherlands", "Belgium", "Italy",
          "Spain", "Portugal", "Austria", "Ireland", "Denmark",
          "Sweden", "Finland", "Poland", "Czech Republic", "Romania",
          "Hungary", "Greece", "Bulgaria", "Croatia", "Slovakia",
          "Slovenia", "Lithuania", "Latvia", "Estonia", "Luxembourg",
          "Malta", "Cyprus",
          "Norway", "Iceland", "Liechtenstein",
          "Switzerland"
        ]
      }
    },
    "excluded_countries": ["Russia", "Belarus"]
  },

  "scraper_logic": {
    "dedup_keys": ["company_domain", "linkedin_url", "email"],
    "discard_if": [
      "Company does not meet enterprise size threshold",
      "Title matches exclusion keywords",
      "Title does not match any inclusion keywords",
      "Company outside approved geography"
    ]
  }
}
